<Window x:Class="Subscription_Manager.EditSubscriptionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:converters="clr-namespace:Subscription_Manager.Converters"
        Title="Edit Subscription"
        Height="520"
        Width="720"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FFD9D9D9">
   

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT COLUMN -->
        <StackPanel Grid.Column="0" Margin="0,0,20,0">

            <TextBlock Text="Subscription Name *"
                       FontFamily="Cooper Black"
                       FontSize="15"/>
            <TextBox x:Name="NameBox"
                     Margin="0,5,0,15"
                     TextChanged="InputChanged"/>

            <TextBlock Text="Cost *"
                       FontFamily="Cooper Black"
                       FontSize="15"/>
            <TextBox x:Name="CostBox"
                     Margin="0,5,0,15"
                     PreviewTextInput="CostBox_PreviewTextInput"
                     TextChanged="InputChanged"/>

            <TextBlock Text="Select Color:"
                       FontFamily="Cooper Black"
                       FontSize="15"/>
            <Button x:Name="ColorButton"
                    Height="30"
                    Margin="0,5,0,15"
                    Click="ColorButton_Click"
                    BorderBrush="#FFED2323"
                    Background="#FF822525"
                    Foreground="White"
                    FontFamily="Cooper Black" Width="85"/>

            <TextBlock Text="Select Category:"
                       FontFamily="Cooper Black"
                       FontSize="15"/>
            <ComboBox x:Name="CategoryBox"
                      Margin="0,5,0,15"
                      SelectedValuePath="."
                      SelectedValue="{Binding Category, Mode=TwoWay}">
                <sys:String>Streaming</sys:String>
                <sys:String>Gaming</sys:String>
                <sys:String>Utilities</sys:String>
                <sys:String>Music</sys:String>
                <sys:String>Productivity</sys:String>
                <sys:String>Shopping</sys:String>
                <sys:String>Other</sys:String>
            </ComboBox>

            <!-- LAST VERIFIED -->
            <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                <TextBlock Text="Last Verified:"
                           VerticalAlignment="Center"
                           Opacity="0.7"
                           FontWeight="Bold" 
                           FontFamily="Cooper Black" 
                           FontSize="16"/>

                <TextBlock x:Name="LastVerifiedText"
                           Margin="5,0,10,0"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"/>

                <Button x:Name="VerifyButton"
                        Content="Verify"
                        Width="70"
                        Height="24"
                        Click="VerifyButton_Click"
                        Background="#FF4C9E20" 
                        BorderBrush="#FF276B31" 
                        FontFamily="Cooper Black"/>
            </StackPanel>

            <TextBlock x:Name="VerifyFeedbackText"
                       Visibility="Collapsed"
                       FontSize="12"
                       Margin="0,0,0,10"/>

            <CheckBox x:Name="ActiveCheck"
                      Content="Active"
                      FontFamily="Cooper Black"
                      Margin="0,5,0,0"/>

            <CheckBox Content="Enable notifications"
                      IsChecked="{Binding NotificationsEnabled, Mode=TwoWay}"
                      FontFamily="Cooper Black"
                      Margin="0,5,0,0"/>

        </StackPanel>

        <!-- RIGHT COLUMN -->
        <StackPanel Grid.Column="1">

            <TextBlock Text="Billing Cycle *"
                       FontFamily="Cooper Black"
                       FontSize="16"/>

            <StackPanel Orientation="Horizontal"
                        Margin="0,5,0,15">
                <RadioButton x:Name="MonthlyRadio"
                             Content="Monthly"
                             GroupName="BillingCycle"
                             FontWeight="Bold"/>

                <RadioButton x:Name="YearlyRadio"
                             Content="Yearly"
                             GroupName="BillingCycle"
                             Margin="20,0,0,0"
                             FontWeight="Bold"/>
            </StackPanel>

            <TextBlock Text="First Billing Date *"
                       FontFamily="Cooper Black"
                       FontSize="16"/>

            <DatePicker x:Name="BillingDatePicker"
                        Margin="0,5,0,15"
                        SelectedDateChanged="InputChanged"/>

            <TextBlock Text="Description"
                       Margin="0,10,0,4"
                       FontFamily="Cooper Black"
                       FontSize="16"/>

            <TextBox x:Name="DescriptionBox"
                     Height="150"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     Text="{Binding Description, Mode=TwoWay}"/>

        </StackPanel>

        <!-- BOTTOM BUTTON SECTION -->
        <StackPanel Grid.ColumnSpan="2"
                    VerticalAlignment="Bottom"
                    Margin="0,20,0,0">

            <TextBlock x:Name="ErrorText"
                       Text="Please fill out all required fields."
                       Foreground="Red"
                       FontWeight="Bold"
                       Visibility="Collapsed"
                       Margin="0,0,0,10"/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">

                <Button Content="Delete"
                        Width="120"
                        Height="42"
                        Click="Delete_Click"
                        Background="#C6451F"
                        Foreground="White"
                        FontWeight="Bold"
                        FontFamily="Cooper Black"
                        FontSize="18"/>

                <Button Content="Cancel (Esc)"
                        Width="120"
                        Margin="8,0,0,0"
                        IsCancel="True"
                        Click="Cancel_Click"
                        Background="#FFFF5757"
                        Foreground="White"
                        FontWeight="Bold"
                        FontFamily="Cooper Black"
                        FontSize="16"/>

                <Button Content="Save (Enter)"
                        Width="120"
                        Height="42"
                        Margin="10,0,0,0"
                        Click="Save_Click"
                        Background="#FFF15A21"
                        Foreground="White"
                        FontWeight="Bold"
                        FontFamily="Cooper Black"
                        FontSize="16"/>

            </StackPanel>
        </StackPanel>

    </Grid>
</Window>